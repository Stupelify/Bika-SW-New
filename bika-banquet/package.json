{
  "name": "bika-banquet",
  "version": "1.0.0",
  "description": "Full-stack banquet operations platform",
  "private": true,
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:db": "docker start bika-banquet-dev-db >/dev/null 2>&1 || docker compose -p bika-banquet-dev -f docker-compose.dev.yml up -d db",
    "dev:db:down": "docker stop bika-banquet-dev-db",
    "dev:db:logs": "docker logs -f bika-banquet-dev-db",
    "dev:with-db": "npm run dev:db && npm run dev",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "build": "npm run build:server && npm run build:client",
    "build:server": "cd server && npm run build",
    "build:client": "cd client && npm run build",
    "start": "concurrently \"npm run start:server\" \"npm run start:client\"",
    "start:server": "cd server && npm start",
    "start:client": "cd client && npm start"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}

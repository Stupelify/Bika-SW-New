{
  "name": "bika-banquet-client",
  "version": "1.0.0",
  "description": "Bika Banquet Dashboard",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:capacitor": "CAPACITOR_BUILD=1 NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL:-https://banquet.bikafood.com/api} next build",
    "cap:sync": "CAPACITOR_BUILD=1 npx cap sync",
    "start": "next start",
    "lint": "next lint",
    "test:e2e": "playwright test",
    "test:e2e:fuzz": "playwright test e2e/qa-forms",
    "test:e2e:capacitor": "playwright test -c playwright.capacitor.config.ts",
    "test:e2e:booking-form": "playwright test -c playwright.booking-form.config.ts",
    "test:e2e:staging-qa": "playwright test -c playwright.staging-qa.config.ts",
    "test:unit:booking-form": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.2.0",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/status-bar": "^8.0.2",
    "@ionic/core": "^8.8.1",
    "@ionic/react": "^8.8.1",
    "@tanstack/react-query": "^5.100.14",
    "axios": "^1.7.2",
    "date-fns": "^3.6.0",
    "lucide-react": "^0.408.0",
    "next": "^14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.1",
    "sonner": "^1.5.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@bika/booking-core": "*",
    "@playwright/test": "^1.60.0",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "jsdom": "^26.1.0",
    "postcss": "^8.4.39",
    "postcss-import": "^16.1.1",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vitest": "^3.2.4"
  },
  "optionalDependencies": {
    "@next/swc-darwin-arm64": "^14.2.33"
  }
}

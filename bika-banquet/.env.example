# Runtime
NODE_ENV=production
SERVER_PORT=5000
JWT_EXPIRES_IN=7d

# Database Configuration
DB_NAME=bika_banquet
DB_USER=postgres
DB_PASSWORD=secure_password_change_me

# JWT Configuration
JWT_SECRET=change-this-to-a-secure-random-string-in-production-min-32-chars

# URLs
CLIENT_URL=https://yourdomain.com
NEXT_PUBLIC_API_URL=/api

# Google Calendar Sync (service account)
GOOGLE_CALENDAR_SYNC_ENABLED=false
GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
GOOGLE_CALENDAR_TIMEZONE=Asia/Kolkata
GOOGLE_CALENDAR_IMPORT_ENABLED=false
GOOGLE_CALENDAR_IMPORT_TIMEZONE=Asia/Kolkata
GOOGLE_CALENDAR_IMPORT_PAST_YEARS=50
GOOGLE_CALENDAR_IMPORT_FUTURE_YEARS=5
GOOGLE_CALENDAR_IMPORT_SOURCES="Venue 1|calendar-id-1@group.calendar.google.com;Venue 2|calendar-id-2@group.calendar.google.com"

# Email Configuration (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@bikabanquet.com

# Optional: Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=5000
AUTH_RATE_LIMIT_WINDOW=15
AUTH_RATE_LIMIT_MAX=1000

    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.10",
    "@types/pdfkit": "^0.13.4",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "prisma": "^5.19.0",
